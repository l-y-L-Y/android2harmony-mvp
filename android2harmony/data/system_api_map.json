      "permissions": ["ohos.permission.ACTIVITY_MOTION (仅计步/心率等)"],
      "adapter_module": "SensorCompat",
      "status": "compiled",
      "priority": 4,
      "probe_app": "指南针 / 水平仪 / 计步",
      "notes": "基础运动/方向传感器无需权限;计步 PEDOMETER 需 ACTIVITY_MOTION。"
    },
    {
      "id": "location",
