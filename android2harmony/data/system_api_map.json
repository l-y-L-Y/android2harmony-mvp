{
  "version": 1,
  "note": "Android -> HarmonyOS system-capability map for OFFLINE (no-backend) apps. Each capability is a family that needs a real runtime adapter (an XxxCompat.ets, like MediaStoreCompat) so the transpiled app actually RUNS the capability, not a mock. 'status' = done (functionally device-verified) | compiled (adapter compiles against the real HarmonyOS SDK + is auto-injected + prompt-bound, pending functional on-device/hardware verification) | partial | planned (adapter not built yet). 'detect' patterns extend analyzer.ANDROID_API_RULES; when a capability is detected the generator injects the adapter module + permissions + a prompt hint. Harmony symbols are pinned/verified at adapter build time by the hvigor compile + on-device probe (the compile is the source of truth; this table is the authoritative draft sourced from official Kit docs).",
  "capabilities": [
    {
      "id": "photos_video",
      "title_cn": "图片/视频库",
      "android_detect": ["MediaStore\\.(Images|Video|Files|Audio)", "EXTERNAL_CONTENT_URI"],
      "android_apis": ["MediaStore", "ContentResolver.query"],
      "harmony_kit": "@kit.MediaLibraryKit",
      "harmony_symbols": ["photoAccessHelper.getPhotoAccessHelper", "getAssets", "FetchOptions"],
      "permissions": ["ohos.permission.READ_IMAGEVIDEO"],
      "adapter_module": "MediaStoreCompat",
      "status": "done",
      "priority": 0,
      "probe_app": "SimpleGallery (相册)",
      "notes": "已实现并实机验证:读设备相册、返回 {uri,name,isVideo}、全屏看图。"
    },
    {
      "id": "audio_record",
      "title_cn": "录音/音频采集",
      "android_detect": ["MediaRecorder", "AudioRecord"],
      "android_apis": ["MediaRecorder.start/stop", "AudioRecord.read"],
      "harmony_kit": "@kit.MediaKit",
      "harmony_symbols": ["media.createAVRecorder", "media.AVRecorderConfig", "media.AudioSourceType.AUDIO_SOURCE_TYPE_MIC"],
      "harmony_alt": "@kit.AudioKit audio.AudioCapturer (低层PCM采集)",
      "permissions": ["ohos.permission.MICROPHONE"],
      "adapter_module": "AudioRecorderCompat",
      "status": "done",
      "priority": 1,
      "probe_app": "录音机 / 语音备忘",
      "notes": "已实现并实机验证(Fossify VoiceRecorder 重转):真麦克风录音→1.2MB m4a→保存。AVRecorder 录到沙箱文件(context.filesDir);AVRecorderProfile(AAC/48k);权限运行时申请。"
    },
    {
      "id": "av_playback",
      "title_cn": "音/视频播放",
      "android_detect": ["MediaPlayer", "ExoPlayer", "SimpleExoPlayer"],
      "android_apis": ["MediaPlayer.setDataSource/start"],
      "harmony_kit": "@kit.MediaKit",
      "harmony_symbols": ["media.createAVPlayer", "AVPlayer.url", "AVPlayer.fdSrc", "prepare/play/pause/seek"],
      "permissions": [],
      "adapter_module": "AVPlayerCompat",
      "status": "wired",
      "priority": 1,
      "probe_app": "音乐 / 视频播放器",
      "notes": "适配器已注入+编译+绑定播放页(VoiceRecorder 播放页);模拟器无法听声做最终验证,待真机/可听环境验证。本地文件无需权限;网络流走 NetworkKit。XComponent 承载视频画面。"
    },
    {
      "id": "key_value",
      "title_cn": "键值存储 (SharedPreferences)",
      "android_detect": ["SharedPreferences", "getSharedPreferences", "PreferenceManager", "DataStore", "preferencesDataStore", "androidx.datastore"],
      "android_apis": ["SharedPreferences.getString/edit().putX"],
      "harmony_kit": "@kit.ArkData",
      "harmony_symbols": ["preferences.getPreferences", "Preferences.put/get/flush"],
      "permissions": [],
      "adapter_module": "PreferencesCompat",
      "status": "compiled",
      "priority": 2,
      "probe_app": "设置 / 简单笔记",
      "notes": "同步语义包成 Promise;key/value 持久到应用沙箱,无需权限。"
    },
    {
      "id": "database",
      "title_cn": "关系型数据库 (Room/SQLite)",
      "android_detect": ["RoomDatabase", "@Database", "@Entity", "@Dao", "SQLiteOpenHelper"],
      "android_apis": ["Room DAO", "SQLiteDatabase.rawQuery"],
      "harmony_kit": "@kit.ArkData",
      "harmony_symbols": ["relationalStore.getRdbStore", "RdbStore.executeSql/insert/query", "RdbPredicates"],
      "permissions": [],
      "adapter_module": "RelationalStoreAdapter",
      "status": "done",
      "priority": 2,
      "probe_app": "笔记 / 记账 / 待办",
      "notes": "从 @Entity/@Dao 生成 RoomSchema.ets + DaoAdapters.ets + RelationalStoreAdapter.ets;@Dao 方法映射成 typed CRUD,securityLevel S1,无需权限。2026-06-23 真机验证(Pura 90 Pro,fresh 项目 MyNotes):首屏 seed→migrated_room.db 落盘(/data/app/el2/100/database/<bundle>/entry/rdb/),强杀+重启后 sqlite3 拉出同样 5 行(id 1-5 未重种)、4 列含 deadLine、界面列表渲染一致。修复点:@Query 正则 suspend 可选、CREATE TABLE 用真实 @Entity(tableName)、insertRow 按真列过滤+丢弃autogen id=0、注释内逗号导致丢列、prompt 注入真实 DAO 适配器类名禁空壳。"
    },
    {
      "id": "file_storage",
      "title_cn": "本地文件存储",
      "android_detect": ["FileOutputStream", "getFilesDir", "getExternalFilesDir", "openFileOutput"],
      "android_apis": ["File", "FileInputStream/OutputStream"],
      "harmony_kit": "@kit.CoreFileKit",
      "harmony_symbols": ["fileIo (fs.openSync/read/write)", "fileUri", "context.filesDir", "picker.DocumentViewPicker"],
      "permissions": [],
      "adapter_module": "FileCompat",
      "status": "partial",
      "priority": 2,
      "probe_app": "文件管理 / 导出",
      "notes": "沙箱读写已部分可用;补齐选择器/分享路径与 uri 转换。"
    },
    {
      "id": "camera",
      "title_cn": "拍照/相机",
      "android_detect": ["CameraX", "android.hardware.Camera", "takePicture", "ImageCapture"],
      "android_apis": ["CameraX ImageCapture.takePicture"],
      "harmony_kit": "@kit.CameraKit",
      "harmony_symbols": ["cameraPicker.pick (简易拍照)", "camera.CameraManager (自定义预览)", "XComponent 预览面"],
      "permissions": ["ohos.permission.CAMERA"],
      "adapter_module": "CameraCompat",
      "status": "compiled",
      "priority": 3,
      "probe_app": "相机 / 扫码 / 证件拍照",
      "notes": "优先用 cameraPicker(系统取图,少样板);需要预览/连拍再上 CameraManager。"
