      "permissions": ["ohos.permission.LOCATION", "ohos.permission.APPROXIMATELY_LOCATION"],
      "adapter_module": "LocationCompat",
      "status": "compiled",
      "priority": 4,
      "probe_app": "指南针 / 本地天气 / 运动轨迹",
      "notes": "需同时申请精确+模糊定位;逆地理编码用 geoLocationManager.getAddressesFromLocation。"
    },
    {
      "id": "notification",
